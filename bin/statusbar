#!/usr/bin/env bash
set -euo pipefail
weather=$HOME/.cache/weather
while curl -s 'wttr.in/?m&format=%t%c' > "$weather"; do sleep 300; done &
while echo -en "$(<"$weather")$(nmcli net con | grep -q full && nmcli --fields type,name con show --active | tail -n+2 | awk '{ ty = $1; $1 = ""; print (ty == "wifi" ? "пҮ« " : "пһ–") $0 "  " }' | head -n1)$(if [ -e /sys/class/power_supply/BAT0 ]; then echo -n "пүҖ $(< /sys/class/power_supply/BAT0/capacity)%  "; fi)вҷӘ $(ncmpcpp -q --current-song='%t')  п„і $(date +'%Y-%m-%d')  пҖ— $(date +'%I:%M:%S %p')"; do sleep 1; done
